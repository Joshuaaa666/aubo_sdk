  <!-- ================== 夹爪到钣金 ================== -->
  <link name="gripper_to_plate">
    <visual>
      <geometry>
        <box size="0.005 0.08 0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.005 0.08 0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="gripper_to_plate_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="gripper_to_plate"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
  </joint>

