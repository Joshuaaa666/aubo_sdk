  <joint name="plate_to_kinect_joint" type="fixed">
    <parent link="gripper_to_plate"/>
    <child link="azure_kinect_camera_base"/> 
    <origin xyz="0.03 0 -0.02" rpy="0 0 0"/>
  </joint>

  
  <link name="world" />

  <joint name="world_joint" type="fixed">
    <parent link="world" />
    <child link = "agv_base" />
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
  </joint>
  
  <joint name="base_joint" type="fixed">
    <parent link="agv_base" />
    <child link = "base_link" />
    <origin xyz="0.0 0.0 0.5" rpy="0.0 0.0 1.57" />
  </joint>

